(midiFrequency[m_] := 4402^\(\(m - 69\)/12\);) Tj
T* (centsError[measured_, target_] := 1200Log2[measured/target];) Tj
T* () Tj
T* (bodyLength[rootMidi_, boreID_] := Module[) Tj
T* ({f = midiFrequency[rootMidi], acoustic, bellCorr, reedCorr},) Tj
T* (acoustic = speedOfSoundInPerSec/\(4f\);) Tj
T* (bellCorr = 0.61\(boreID/2\);) Tj
T* (reedCorr = 0.25boreID;) Tj
T* (acoustic - bellCorr - reedCorr) Tj
T* (];) Tj
T* () Tj
T* (holeXFromBell[rootMidi_, offset_, boreID_, holeRatio_] := Module[) Tj
T* ({f = midiFrequency[rootMidi + offset], holeDia, holeCorr, reedCorr, eff, body},) Tj
T* (holeDia = boreIDholeRatio;) Tj
T* (holeCorr = 0.30holeDia;) Tj
T* (reedCorr = 0.25boreID;) Tj
T* (eff = speedOfSoundInPerSec/\(4f\);) Tj
T* (body = bodyLength[rootMidi, boreID];) Tj
T* (body - \(eff - reedCorr - holeCorr\)) Tj
T* (];) Tj
T* () Tj
T* (variants = {) Tj
T* (< | "ID" -> "CLM-SOP-C4", "RootMIDI" -> 60, "BoreID" -> 0.500 | >,) Tj
T* (< | "ID" -> "CLM-ALT-G3", "RootMIDI" -> 55, "BoreID" -> 0.625 | >,) Tj
