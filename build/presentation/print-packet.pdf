T* (holeRatios = {0.32, 0.36, 0.38, 0.34, 0.38, 0.40, 0.30, 0.34, 0.32};) Tj
T* () Tj
T* (familyTable = Table[) Tj
T* (With[{v = variants[[i]]},) Tj
T* (< |) Tj
T* ("ID" -> v["ID"],) Tj
T* ("RootHz" -> midiFrequency[v["RootMIDI"]],) Tj
T* ("BodyLengthIn" -> bodyLength[v["RootMIDI"], v["BoreID"]],) Tj
T* ("HolePositionsFromBellIn" -> MapThread[) Tj
T* (holeXFromBell[v["RootMIDI"], #1, v["BoreID"], #2]&,) Tj
T* ({holeOffsets, holeRatios}) Tj
T* (]) Tj
T* (| >) Tj
T* (],) Tj
T* ({i, Length[variants]}) Tj
T* (];) Tj
T* () Tj
T* (Dataset[familyTable]) Tj
T* () Tj
